Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"===", 
    RowBox[{"Example", " ", "run"}], "==="}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", 
        RowBox[{"Kernels", "[", "]"}], "]"}], "==", "0"}], ",", 
      RowBox[{"LaunchKernels", "[", "12", "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Running with \>\"", ",", 
     RowBox[{"Length", "[", 
      RowBox[{"Kernels", "[", "]"}], "]"}], ",", "\"\< kernels\>\""}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Nconv", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tol", "=", "0.01"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dtol", "=", "0.6"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lmaxhard", "=", "250"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mchi", "=", "1.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"log10mphi", "=", 
     RowBox[{"-", "4.0"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"log10alpha", "=", 
     RowBox[{"-", "3.4"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sign", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"minv", "=", 
    RowBox[{"minimumv", "[", 
     RowBox[{"1.0", ",", 
      RowBox[{"10", "^", "log10mphi"}], ",", 
      RowBox[{"10", "^", "log10alpha"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"maxv", "=", 
    RowBox[{"maximumv", "[", 
     RowBox[{"1.0", ",", 
      RowBox[{"10", "^", "log10mphi"}], ",", 
      RowBox[{"10", "^", "log10alpha"}], ",", "0.01"}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vgrid", "=", 
     RowBox[{"10", "^", 
      RowBox[{"Subdivide", "[", 
       RowBox[{
        RowBox[{"Log10", "[", "minv", "]"}], ",", 
        RowBox[{"Log10", "[", "maxv", "]"}], ",", "16"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Block", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[Kappa]", "=", 
            RowBox[{"kappa", "[", 
             RowBox[{"mchi", ",", 
              RowBox[{"10", "^", "log10mphi"}], ",", "v"}], "]"}]}], ",", 
           RowBox[{"\[Beta]", "=", 
            RowBox[{"beta", "[", 
             RowBox[{"mchi", ",", 
              RowBox[{"10", "^", "log10mphi"}], ",", 
              RowBox[{"10", "^", "log10alpha"}], ",", "v"}], "]"}]}], ",", 
           "res", ",", "sigv"}], "}"}], ",", 
         RowBox[{
          RowBox[{"res", "=", 
           RowBox[{"partialwavesumConverged", "[", 
            RowBox[{
            "\[Kappa]", ",", "\[Beta]", ",", "sign", ",", "lmaxhard", ",", 
             "Nconv", ",", "tol", ",", "dtol"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"sigv", "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"4", "*", 
              RowBox[{"Pi", "/", 
               RowBox[{
                RowBox[{"momentum", "[", 
                 RowBox[{"mchi", ",", "v"}], "]"}], "^", "2"}]}]}], ")"}], 
            "*", 
            RowBox[{
             RowBox[{"res", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "/", 
             RowBox[{"mchigram", "[", "mchi", "]"}]}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"v", ",", "sigv", ",", 
            RowBox[{"res", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"v", ",", "vgrid"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"TableForm", "[", 
      RowBox[{"results", ",", 
       RowBox[{"TableHeadings", "->", 
        RowBox[{"{", 
         RowBox[{"None", ",", 
          RowBox[{"{", 
           RowBox[{
           "\"\<v (km/s)\>\"", ",", "\"\<\[Sigma]V (cm^2/g)\>\"", ",", 
            "\"\<lconv\>\""}], "}"}]}], "}"}]}]}], "]"}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "logarithmic", " ", "slope", " ", "d", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"log", " ", "sigma"}], ")"}], "/", "d"}], 
     RowBox[{"(", 
      RowBox[{"log", " ", "v"}], ")"}], " ", "by", " ", "finite", " ", 
     "differences"}], "*)"}], 
   RowBox[{
    RowBox[{"logv", "=", 
     RowBox[{"Log10", "[", 
      RowBox[{"results", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"logsig", "=", 
     RowBox[{"Log10", "[", 
      RowBox[{"results", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"logslope", "=", 
     RowBox[{
      RowBox[{"Differences", "[", "logsig", "]"}], "/", 
      RowBox[{"Differences", "[", "logv", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Midpoints", " ", "of", " ", "v", " ", "for", " ", "plotting", " ", "the",
      " ", "slope"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"vmid", "=", 
     RowBox[{"10", "^", 
      RowBox[{"MovingAverage", "[", 
       RowBox[{"logv", ",", "2"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"plot1", "=", 
     RowBox[{"ListLogLogPlot", "[", 
      RowBox[{
       RowBox[{"results", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}], ",", 
       RowBox[{"Joined", "->", "True"}], ",", 
       RowBox[{"PlotMarkers", "->", "Automatic"}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<v (km/s)\>\"", ",", "\"\<\[Sigma]V (cm^2/g)\>\""}], 
         "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"StringForm", "[", 
         RowBox[{
         "\"\<log10(mphi)=``, log10(alpha)=``\>\"", ",", "log10mphi", ",", 
          "log10alpha"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"plot2", "=", 
     RowBox[{"ListLogLinearPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"vmid", ",", "logslope"}], "}"}], "]"}], ",", 
       RowBox[{"Joined", "->", "True"}], ",", 
       RowBox[{"PlotMarkers", "->", "Automatic"}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{
         "\"\<v (km/s)\>\"", ",", "\"\<d log \[Sigma]V / d log v\>\""}], 
         "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Logarithmic slope\>\""}]}], "]"}]}], 
    ";"}]}]}]], "Input",
